# Default: treat all files as text and normalize to LF
* text=auto eol=lf

# Python source
*.py text eol=lf

# XML files (addon.xml, settings.xml, etc.)
*.xml text eol=lf

# JSON
*.json text eol=lf

# Markdown / documentation
*.md text eol=lf
*.txt text eol=lf

# Shell scripts
*.sh text eol=lf

# Kodi-specific files
*.po text eol=lf
*.pot text eol=lf

# Binary files (never touch line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.7z binary
*.db binary
